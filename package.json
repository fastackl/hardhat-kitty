{
  "name": "@fastackl/hardhat-kitty",
  "version": "0.1.0",
  "description": "Reusable deploy/initialize/verify task kit for Hardhat 3.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hardhat": {
      "types": "./dist/hardhat.d.ts",
      "default": "./dist/hardhat.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "kitty:config:init": "tsx src/kit/cli/init.ts",
    "test": "hardhat test"
  },
  "bin": {
    "kitty-init": "./dist/kit/cli/init.js"
  },
  "peerDependencies": {
    "ethers": "^6.16.0",
    "hardhat": "^3.1.0"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-verify": "^3.0.2",
    "axios": "^1.7.0",
    "colors": "^1.4.0",
    "glob": "^13.0.6",
    "table": "^6.9.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-mocha": "^3.0.10",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.2",
    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
